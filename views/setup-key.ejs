<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Setup Key</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="auth-body">
    <div class="auth-card">
      <h1>Master Key Access</h1>
      <p>Masukkan key yang digenerate saat server pertama kali berjalan.</p>
      <% if (error) { %>
      <div class="alert error"><%= error %></div>
      <% } %>
      <% if (success) { %>
      <div class="alert success"><%= success %></div>
      <a href="/panel" class="auth-link">Masuk ke Panel</a>
      <% } %>
      <form action="/setup-key" method="post">
        <label for="masterKey">Master Key</label>
        <input id="masterKey" name="masterKey" type="password" required />
        <button type="submit">Unlock</button>
      </form>
      <a href="/" class="auth-link">Kembali ke Landing</a>
    </div>
  </body>
</html>
