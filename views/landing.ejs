<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Landing Page</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="landing-body">
    <canvas id="bgNetwork"></canvas>
    <div class="blood-layer" id="bloodLayer"></div>

    <header class="top-nav">
      <nav class="menu-wrap">
        <div class="dropdown">
          <button class="dropbtn" type="button">Store Product</button>
          <div class="dropdown-content">
            <% storeProducts.filter((p) => p.category === "tools").forEach((p) => { %>
            <button
              class="dropdown-product-btn"
              type="button"
              data-id="<%= p._id %>"
              data-name="<%= p.name %>"
              data-category="<%= p.category %>"
              data-desc="<%= p.description || '' %>"
              data-price="<%= p.priceIdr %>"
            ><%= p.name %></button>
            <% }) %>
            <% storeProducts.filter((p) => p.category === "script").forEach((p) => { %>
            <button
              class="dropdown-product-btn"
              type="button"
              data-id="<%= p._id %>"
              data-name="<%= p.name %>"
              data-category="<%= p.category %>"
              data-desc="<%= p.description || '' %>"
              data-price="<%= p.priceIdr %>"
            ><%= p.name %></button>
            <% }) %>
          </div>
        </div>
      </nav>
    </header>

    <main class="hero">
      <h1 class="logo-glitch" data-text="SweGeL .Inc">SweGeL .Inc</h1>
      <p>
        Priv8 Tools and scripts designed for those who know what they are doing and know the rules
      </p>
      <a class="buy-now-btn" href="https://t.me/SweGeL_Corps" target="_blank" rel="noopener noreferrer">
        Buy Now
      </a>
    </main>

    <section class="store-section">
      <h2>Store Products</h2>
      <div class="store-grid">
        <% storeProducts.forEach((p) => { %>
        <button
          class="store-card"
          type="button"
          data-id="<%= p._id %>"
          data-name="<%= p.name %>"
          data-category="<%= p.category %>"
          data-desc="<%= p.description || '' %>"
          data-price="<%= p.priceIdr %>"
          data-cover="<%= p.coverImage || '' %>"
        >
          <div class="store-card-title"><%= p.name %></div>
          <div class="store-card-price">Rp<%= Number(p.priceIdr || 0).toLocaleString("id-ID") %></div>
        </button>
        <% }) %>
      </div>
    </section>

    <div id="productModal" class="store-modal hidden">
      <div class="store-modal-card">
        <button id="closeProductModal" class="close-btn" type="button">Close</button>
        <h3 id="pmName">Product</h3>
        <p id="pmCategory">Category</p>
        <p id="pmDesc">Description</p>
        <p id="pmPrice">Price</p>
        <div class="row">
          <input id="buyerEmail" type="email" placeholder="buyer email" />
          <select id="payMethod">
            <option value="bank">Bank Transfer</option>
            <option value="usdt">USDT TRC20</option>
          </select>
          <button id="buyNowBtn" type="button">Buy Now</button>
        </div>
        <div id="invoiceBox" class="invoice-box hidden"></div>
      </div>
    </div>

    <script src="/js/landing.js"></script>
    <script>
      const cards = Array.from(document.querySelectorAll(".store-card"));
      const dropdownTriggers = Array.from(document.querySelectorAll(".dropdown-product-btn"));
      const modal = document.getElementById("productModal");
      const closeBtn = document.getElementById("closeProductModal");
      const pmName = document.getElementById("pmName");
      const pmCategory = document.getElementById("pmCategory");
      const pmDesc = document.getElementById("pmDesc");
      const pmPrice = document.getElementById("pmPrice");
      const buyerEmail = document.getElementById("buyerEmail");
      const payMethod = document.getElementById("payMethod");
      const buyNowBtn = document.getElementById("buyNowBtn");
      const invoiceBox = document.getElementById("invoiceBox");

      let selectedProductId = null;
      let lastOrderId = null;

      function openModal(data) {
        selectedProductId = data.id;
        pmName.textContent = data.name;
        pmCategory.textContent = `Category: ${String(data.category || "other").toUpperCase()}`;
        pmDesc.textContent = data.desc || "No description.";
        pmPrice.textContent = `Price: Rp${Number(data.price || 0).toLocaleString("id-ID")}`;
        invoiceBox.classList.add("hidden");
        invoiceBox.innerHTML = "";
        modal.classList.remove("hidden");
      }

      cards.forEach((c) => {
        c.addEventListener("click", () => {
          openModal({
            id: c.dataset.id,
            name: c.dataset.name,
            category: c.dataset.category,
            desc: c.dataset.desc,
            price: c.dataset.price
          });
        });
      });

      dropdownTriggers.forEach((btn) => {
        btn.addEventListener("click", () => {
          openModal({
            id: btn.dataset.id,
            name: btn.dataset.name,
            category: btn.dataset.category,
            desc: btn.dataset.desc,
            price: btn.dataset.price
          });
        });
      });

      closeBtn.addEventListener("click", () => modal.classList.add("hidden"));
      modal.addEventListener("click", (e) => {
        if (e.target === modal) modal.classList.add("hidden");
      });

      async function api(url, method = "GET", body = null) {
        const opt = { method, headers: {} };
        if (body) {
          opt.headers["Content-Type"] = "application/json";
          opt.body = JSON.stringify(body);
        }
        const res = await fetch(url, opt);
        const json = await res.json().catch(() => ({}));
        if (!res.ok || json.ok === false) {
          throw new Error(json.message || "Request failed");
        }
        return json;
      }

      async function pollOrderStatus(orderId) {
        try {
          const data = await api(`/api/store/order/${encodeURIComponent(orderId)}/status`);
          const order = data.order || {};
          if (order.status === "pending") {
            const statusEl = document.getElementById("paidStatus");
            if (statusEl) statusEl.textContent = "Waiting for Telegram admin approval...";
            setTimeout(() => pollOrderStatus(orderId), 3000);
            return;
          }
          if (order.status === "approved") {
            invoiceBox.innerHTML = `<p class="ok">Payment approved. Download unlocked.</p>
            <p><a href="${order.downloadLink}" target="_blank" rel="noopener noreferrer">Download Product</a></p>`;
            return;
          }
          if (order.status === "rejected") {
            invoiceBox.innerHTML = `<p class="bad">Payment rejected by admin.</p>`;
          }
        } catch (e) {
          invoiceBox.innerHTML = `<p class="bad">${e.message}</p>`;
        }
      }

      buyNowBtn.addEventListener("click", async () => {
        try {
          const email = String(buyerEmail.value || "").trim();
          if (!email) throw new Error("Isi email buyer dulu.");
          const payload = {
            productId: selectedProductId,
            buyerEmail: email,
            paymentMethod: payMethod.value
          };
          const data = await api("/api/store/order", "POST", payload);
          const order = data.order || {};
          const payment = data.payment || {};
          lastOrderId = order.id;
          const usdtLine = order.paymentMethod === "usdt" ? `USDT Amount: ${order.usdtAmount || "-"} (TRC20)` : "";
          invoiceBox.classList.remove("hidden");
          invoiceBox.innerHTML = `
            <p><b>Invoice:</b> ${order.invoiceCode}</p>
            <p><b>Status:</b> ${order.status}</p>
            <p><b>Amount:</b> Rp${Number(order.amountIdr || 0).toLocaleString("id-ID")}</p>
            ${usdtLine ? `<p>${usdtLine}</p>` : ""}
            <hr/>
            <p><b>Bank:</b> ${payment.bank || "Blu BCA Digital"}</p>
            <p><b>No. Rek:</b> ${payment.accountNumber || "005658853460"}</p>
            <p><b>Nama:</b> ${payment.accountName || "Novita"}</p>
            <p><b>USDT TRC20:</b> ${payment.usdtAddress || "TSReaKxV5swr6Fmj6uSzt7wLnnxETMzwED"}</p>
            <button id="paidBtn" type="button" class="paid-btn">Paid</button>
            <p id="paidStatus" class="warn">Click Paid after payment, then wait for Telegram approval.</p>
          `;
          const paidBtn = document.getElementById("paidBtn");
          if (paidBtn) {
            paidBtn.addEventListener("click", () => {
              paidBtn.disabled = true;
              paidBtn.textContent = "Checking...";
              pollOrderStatus(lastOrderId);
            });
          }
        } catch (e) {
          invoiceBox.classList.remove("hidden");
          invoiceBox.innerHTML = `<p class="bad">${e.message}</p>`;
        }
      });
    </script>
  </body>
</html>
