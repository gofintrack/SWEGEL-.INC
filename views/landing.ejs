<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Landing Page</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="landing-body">
    <canvas id="bgNetwork"></canvas>
    <div class="blood-layer" id="bloodLayer"></div>

    <header class="top-nav">
      <nav class="menu-wrap">
        <div class="dropdown">
          <button class="dropbtn" type="button">Tools</button>
          <div class="dropdown-content">
            <% tools.forEach((item) => { %>
            <a href="<%= item.url %>" target="_blank" rel="noopener noreferrer"><%= item.name %></a>
            <% }) %>
          </div>
        </div>
        <div class="dropdown">
          <button class="dropbtn" type="button">Script</button>
          <div class="dropdown-content">
            <% scripts.forEach((item) => { %>
            <a href="<%= item.url %>" target="_blank" rel="noopener noreferrer"><%= item.name %></a>
            <% }) %>
          </div>
        </div>
      </nav>
    </header>

    <main class="hero">
      <h1 class="logo-glitch" data-text="SweGeL .Inc">SweGeL .Inc</h1>
      <p>
        Priv8 Tools and scripts designed for those who know what they are doing and know the rules
      </p>
      <a class="buy-now-btn" href="https://t.me/SweGeL_Corps" target="_blank" rel="noopener noreferrer">
        Buy Now
      </a>
    </main>

    <script src="/js/landing.js"></script>
  </body>
</html>
